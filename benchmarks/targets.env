# Product-level benchmark gates for the editor core.
#
# These targets are intentionally aggressive. They are measured on generated
# 10 MiB fixtures from scripts/generate-benchmark-fixtures.sh.

ARTISAN_BENCH_COLD_CLI_OPEN_MS_MAX=250
ARTISAN_BENCH_APP_OPEN_MS_MAX=15
ARTISAN_BENCH_IMMEDIATE_BOTTOM_RENDER_MS_MAX=25
ARTISAN_BENCH_IMMEDIATE_BOTTOM_NON_EMPTY_LINES_MIN=1
ARTISAN_BENCH_INDEX_ON_SCROLL_COUNT_MIN=1
ARTISAN_BENCH_INDEX_ON_DRAW_COUNT_MAX=0
ARTISAN_BENCH_FULL_INDEX_MS_MAX=35
ARTISAN_BENCH_SCROLL_AVG_STEP_MS_MAX=8
ARTISAN_BENCH_NAVIGATION_AVG_MOVE_MS_MAX=8
ARTISAN_BENCH_HIGHLIGHT_AVG_LINE_MS_MAX=0.05
ARTISAN_BENCH_INSERT_AVG_CHAR_MS_MAX=4
ARTISAN_BENCH_DELETE_AVG_CHAR_MS_MAX=4
ARTISAN_BENCH_NEWLINE_AVG_INSERT_MS_MAX=8
ARTISAN_BENCH_PASTE_1KB_MS_MAX=8
ARTISAN_BENCH_BOTTOM_INSERT_DELETE_MS_MAX=12
